{
  "version": 2,
  "routes": [
    {
      "src": "/sw.js",
      "headers": { "cache-control": "no-cache, no-store, must-revalidate" },
      "dest": "/sw.js"
    },
    {
      "src": "/manifest.json",
      "headers": { "cache-control": "no-cache, no-store, must-revalidate" },
      "dest": "/manifest.json"
    },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
